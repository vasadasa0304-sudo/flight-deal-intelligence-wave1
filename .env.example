# Copy this file to .env for local development.
# Do not commit real credentials.

APP_ENV=local
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/flight_deals
POSTGRES_DB=flight_deals
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Wave1 scope controls
WAVE_SCOPE=WAVE1
WAVE1_GEOGRAPHY="Middle East + Turkey"
WAVE1_HUBS=IST,SAW,DXB,AUH,RUH,JED,DOH,CAI
WAVE1_AIRLINES=TK,PC,EK,FZ,QR,EY,SV,XY,MS,G9
WAVE1_BOOKING_WINDOWS_DAYS=14,60
WAVE1_MVP_CABINS=ECONOMY,BUSINESS
SUPPORTED_CABINS=ECONOMY,PREMIUM_ECONOMY,BUSINESS,FIRST
DISPLAY_CURRENCY=USD

# Amadeus API
# Set AMADEUS_ENV=production only when ready to call the live endpoint (see README).
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test
AMADEUS_MAX_CONCURRENCY=5
AMADEUS_TIMEOUT_SECONDS=25.0

# Duffel API
DUFFEL_API_KEY=

# FX rates (Frankfurter is the only supported provider; leave as-is unless overriding in tests)
FX_PROVIDER=FRANKFURTER
