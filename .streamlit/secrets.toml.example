# Copy this file to secrets.toml and fill in your values.
# secrets.toml is git-ignored — never commit it.
# Paste the contents into the Streamlit Community Cloud secrets manager as-is.

DATABASE_URL = "postgresql+psycopg://user:password@host:5432/dbname"

# Optional — leave blank if not yet configured
AMADEUS_CLIENT_ID     = ""
AMADEUS_CLIENT_SECRET = ""

# Duffel test key: platform.duffel.com → API Keys → Create test key (prefix duffel_test_)
# Leave blank to fall back to the two-strike phantom fare rule.
DUFFEL_API_KEY        = ""
